---
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Resume from '../components/Resume.astro';
import Portfolio from '../components/Portfolio.astro';
import Contact from '../components/Contact.astro';
import BootLoader from '../components/BootLoader.astro';
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <meta name="description" content="Veera Kumar - Network Engineer, IT Consultant, Cloud Technology Enthusiast, and Traveller. Senior Cloud Support Engineer at DigitalOcean." />
    <meta name="keywords" content="Veera Kumar, Network Engineer, DevOps, Cloud Engineer, IT Consultant, DigitalOcean" />
    <meta name="author" content="Veera Kumar" />
    
    <meta property="og:title" content="Veera Kumar | Network Engineer & Cloud Enthusiast" />
    <meta property="og:description" content="Senior Cloud Support Engineer at DigitalOcean with expertise in networking, DevOps, and cloud technologies." />
    <meta property="og:type" content="website" />
    
    <title>Veera Kumar | Network Engineer & Cloud Enthusiast</title>
  </head>
  <body>
    <BootLoader />
    <div class="main-content">
      <Navbar />
      <main>
        <Hero />
        <About />
        <Resume />
        <Portfolio />
        <Contact />
      </main>
    </div>
  </body>
</html>
