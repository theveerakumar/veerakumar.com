---
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Resume from '../components/Resume.astro';
import Portfolio from '../components/Portfolio.astro';
import Contact from '../components/Contact.astro';
import BootLoader from '../components/BootLoader.astro';
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <meta name="description" content="Veera Kumar - Senior Cloud Support Engineer at DigitalOcean. Expertise in cloud infrastructure, DevOps, networking, and Linux systems administration." />
    <meta name="keywords" content="Veera Kumar, Cloud Support Engineer, DigitalOcean, DevOps, Cloud Engineer, Linux, AWS, Kubernetes" />
    <meta name="author" content="Veera Kumar" />
    
    <meta property="og:title" content="Veera Kumar | Cloud Support Engineer & Cloud Enthusiast" />
    <meta property="og:description" content="Senior Cloud Support Engineer at DigitalOcean with expertise in cloud infrastructure, DevOps, and networking." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://veerakumar.com" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@TheVeeraKumar" />
    <meta name="twitter:title" content="Veera Kumar | Cloud Support Engineer" />
    
    <title>Veera Kumar | Cloud Support Engineer at DigitalOcean</title>
  </head>
  <body>
    <BootLoader />
    <div class="main-content">
      <Navbar />
      <main>
        <Hero />
        <About />
        <Resume />
        <Portfolio />
        <Contact />
      </main>
    </div>
  </body>
</html>
