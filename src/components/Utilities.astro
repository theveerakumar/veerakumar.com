---
---

<section id="utilities" class="section">
  <div class="section-header animate-on-scroll">
    <h2 class="section-title"><span class="prompt">$</span> ls utilities/</h2>
    <div class="section-underline"></div>
  </div>
  <div class="utilities-intro animate-on-scroll">
    <p>Stock analysis, market intelligence, and financial calculators — all from your terminal.</p>
  </div>
  <div class="utilities-grid">
    <div class="terminal-card animate-on-scroll">
      <div class="terminal-card-header">
        <span class="dot"></span>
        <span class="prompt">./stockalysis.sh --analyze</span>
      </div>
      <div class="utilities-card-body">
        <div class="utilities-pills">
          <span class="pill">RSI</span>
          <span class="pill">MACD</span>
          <span class="pill">SMA/EMA</span>
          <span class="pill">Bollinger</span>
          <span class="pill">Pivot Points</span>
          <span class="pill">Fibonacci</span>
        </div>
        <div class="utilities-card-footer">
          <a href="/stockalysis/" target="_blank" class="utilities-link">Launch Stockalysis →</a>
        </div>
      </div>
    </div>
    <div class="terminal-card animate-on-scroll">
      <div class="terminal-card-header">
        <span class="dot"></span>
        <span class="prompt">./seaborn.sh --calculators</span>
      </div>
      <div class="utilities-card-body">
        <div class="utilities-pills">
          <span class="pill">Rental Yield</span>
          <span class="pill">EMI Calculator</span>
          <span class="pill">Affordability</span>
        </div>
        <div class="utilities-card-footer">
          <a href="/seaborn/" target="_blank" class="utilities-link">Launch Seaborn →</a>
        </div>
      </div>
    </div>
    <div class="terminal-card animate-on-scroll">
      <div class="terminal-card-header">
        <span class="dot"></span>
        <span class="prompt">./stockvedic.sh --dashboard</span>
      </div>
      <div class="utilities-card-body">
        <div class="utilities-pills">
          <span class="pill">NSE</span>
          <span class="pill">Screener</span>
          <span class="pill">Fundamentals</span>
          <span class="pill">Technical</span>
          <span class="pill">Pivot Points</span>
          <span class="pill">Entry Zone</span>
        </div>
        <div class="utilities-card-footer">
          <a href="/stockvedic/" target="_blank" class="utilities-link">Launch StockVedic →</a>
        </div>
      </div>
    </div>
    <div class="terminal-card animate-on-scroll">
      <div class="terminal-card-header">
        <span class="dot"></span>
        <span class="prompt">./market-intel.sh --analyze</span>
      </div>
      <div class="utilities-card-body">
        <div class="utilities-pills">
          <span class="pill">Entry Detection</span>
          <span class="pill">Market Regime</span>
          <span class="pill">Risk Metrics</span>
          <span class="pill">ADX/Keltner</span>
          <span class="pill">Backtest</span>
          <span class="pill">Screener</span>
        </div>
        <div class="utilities-card-footer">
          <a href="/market-intelligence/" target="_blank" class="utilities-link">Launch Market Intel Pro →</a>
        </div>
      </div>
    </div>
  </div>
</section>
